@page "/"
@using Microsoft.Extensions.Logging
@using Soenneker.Blazor.Utils.Clipboard.Abstract
@using Soenneker.Blazor.Utils.Clipboard.Dtos
@using Soenneker.Blazor.Utils.Clipboard.Enums
@inject IClipboardUtil Clipboard
@inject ILogger<Index> Logger

<Div Space="Space.Y.Is6">
    <DemoPanel Title="Permission state" Description="Clipboard read/write permission from the browser.">
        <DemoButtonRow>
            <Span Class="@PermissionBadgeClass(_readPermission)">Read: @_readPermission</Span>
            <Span Class="@PermissionBadgeClass(_writePermission)">Write: @_writePermission</Span>
            <Button OnClick="RefreshPermissionState" Disabled="@_isBusy">Refresh</Button>
        </DemoButtonRow>
    </DemoPanel>

    <DemoPanel Title="Plain text" Description="Copy and paste plain text.">
        <Field>
            <FieldLabel For="text-input">Copy</FieldLabel>
            <FieldBody>
                <Input Id="text-input" @bind-Value="_textToWrite" Placeholder="Type something…" />
            </FieldBody>
        </Field>
        <DemoButtonRow>
            <Button OnClick="WriteToClipboard" Disabled="@_isBusy">Write text</Button>
            <Button OnClick="ReadFromClipboard" Disabled="@_isBusy" Variant="ButtonVariant.Secondary">Read text</Button>
            <Button OnClick="ClearClipboard" Disabled="@_isBusy" Variant="ButtonVariant.Outline">Clear</Button>
        </DemoButtonRow>
        @if (!string.IsNullOrEmpty(_readResult))
        {
            <Div Rounded="Rounded.Md"
                 Border="Border.Is1"
                 BorderColor="BorderColor.Border"
                 BackgroundColor="BackgroundColor.Muted"
                 Padding="Padding.Is4"
                 TextSize="TextSize.Sm">
                @_readResult
            </Div>
        }
    </DemoPanel>

    <DemoPanel Title="All MIME types" Description="Read text, HTML, images, and other formats from the clipboard.">
        <Button OnClick="ReadAllTypes" Disabled="@_isBusy">Read clipboard (all types)</Button>
        @if (_readItems?.Count > 0)
        {
            <Div Space="Space.Y.Is4">
                @foreach (ClipboardItemDto item in _readItems)
                {
                    <Div Rounded="Rounded.Md"
                         Border="Border.Is1"
                         BorderColor="BorderColor.Border"
                         Padding="Padding.Is4"
                         Space="Space.Y.Is2">
                        @foreach (KeyValuePair<string, string> kv in item.Types)
                        {
                            string value = kv.Value;
                            string preview = value.Length > 120 ? value.Substring(0, 120) + "…" : value;
                            <Paragraph Margin="Margin.Is0" TextSize="TextSize.Xs" TextColor="TextColor.Primary">@kv.Key</Paragraph>
                            @if (value.StartsWith("data:image/", StringComparison.OrdinalIgnoreCase))
                            {
                                <img src="@value" alt="Pasted image" class="clipboard-preview-img" />
                            }
                            else
                            {
                                <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm" Class="break-all whitespace-pre-wrap">@preview</Paragraph>
                            }
                        }
                    </Div>
                }
            </Div>
        }
    </DemoPanel>

    @if (!string.IsNullOrEmpty(_message))
    {
        @if (_messageIsError)
        {
            <Alert Variant="AlertVariant.Danger">
                <AlertMessage>Notice</AlertMessage>
                <AlertDescription>@_message</AlertDescription>
            </Alert>
        }
        else
        {
            <Alert Variant="AlertVariant.Info">
                <AlertMessage>Notice</AlertMessage>
                <AlertDescription>@_message</AlertDescription>
            </Alert>
        }
    }
</Div>

@code {
    private string _textToWrite = "";
    private string _readResult = "";
    private string _message = "";
    private string _readPermission = "—";
    private string _writePermission = "—";
    private IReadOnlyList<ClipboardItemDto>? _readItems;
    private bool _isBusy;
    private bool _messageIsError;

    private static string PermissionBadgeClass(string state) =>
        $"inline-flex rounded-full border px-3 py-1 text-xs font-mono {state.ToLowerInvariant() switch
        {
            "granted" => "border-green-500/30 bg-green-500/10 text-green-600 dark:text-green-400",
            "denied" => "border-red-500/30 bg-red-500/10 text-red-600 dark:text-red-400",
            "prompt" => "border-amber-500/30 bg-amber-500/10 text-amber-700 dark:text-amber-400",
            _ => "border-border bg-muted text-muted-foreground"
        }}";

    protected override async Task OnInitializedAsync()
    {
        await RefreshPermissionState();
    }

    private async Task RefreshPermissionState()
    {
        _isBusy = true;
        _message = "";
        try
        {
            ClipboardPermissionState read = await Clipboard.GetReadPermissionState();
            ClipboardPermissionState write = await Clipboard.GetWritePermissionState();
            _readPermission = read.ToString();
            _writePermission = write.ToString();
        }
        catch (Exception ex)
        {
            _message = $"Permission check: {ex.Message}";
            _messageIsError = true;
            Logger.LogWarning(ex, "Permission state failed");
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task WriteToClipboard()
    {
        _isBusy = true;
        _message = "";
        _messageIsError = false;
        try
        {
            await Clipboard.WriteText(_textToWrite);
            _message = "Copied to clipboard.";
        }
        catch (Exception ex)
        {
            _message = ex.Message;
            _messageIsError = true;
            Logger.LogWarning(ex, "Write to clipboard failed");
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task ReadFromClipboard()
    {
        _isBusy = true;
        _readResult = "";
        _readItems = null;
        _message = "";
        _messageIsError = false;
        try
        {
            _readResult = await Clipboard.ReadText();
            _message = string.IsNullOrEmpty(_readResult) ? "Clipboard is empty or read permission not granted." : "Read successful.";
            if (string.IsNullOrEmpty(_readResult))
                _messageIsError = true;
        }
        catch (Exception ex)
        {
            _message = ex.Message;
            _messageIsError = true;
            Logger.LogWarning(ex, "Read from clipboard failed");
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task ClearClipboard()
    {
        _isBusy = true;
        _message = "";
        _messageIsError = false;
        try
        {
            await Clipboard.Clear();
            _readResult = "";
            _readItems = null;
            _message = "Clipboard cleared.";
        }
        catch (Exception ex)
        {
            _message = ex.Message;
            _messageIsError = true;
            Logger.LogWarning(ex, "Clear clipboard failed");
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task ReadAllTypes()
    {
        _isBusy = true;
        _readItems = null;
        _message = "";
        _messageIsError = false;
        try
        {
            _readItems = await Clipboard.Read();
            _message = _readItems.Count == 0 ? "No items or read permission not granted." : $"Read {_readItems.Count} item(s).";
            if (_readItems.Count == 0)
                _messageIsError = true;
        }
        catch (Exception ex)
        {
            _message = ex.Message;
            _messageIsError = true;
            Logger.LogWarning(ex, "Read all types failed");
        }
        finally
        {
            _isBusy = false;
        }
    }
}
